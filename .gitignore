# Ignore Gradle build output directory
build

# Ignore VSCode configuration directory
.vscode/

# Built application files
*.apk
*.aar
*.jar
*.so

# Files for the ART/Dalvik VM
*.dex

# Java class files
*.class

# Generated files
bin/
gen/
out/

# Android Studio Navigation editor temp files
.navigation/

# The gradle daemon caches between builds
.gradle
.cxx/
.build/

# Local configuration file (sdk path, etc)
local.properties

# Proguard folder generated by ProGuard
.proguard/

# Log Files
*.log

# Android Studio captures
*.cap

# Firebase Realtime Config Template
google-services.json

# External Native Build outputs
.externalNativeBuild
.cxx/
*.so

# NDK
obj/
.libs/

# AprilTag 临时文件
apriltag/build/
apriltag/.cxx/
apriltag/obj/
apriltag/.build/

# AprilTag 示例和测试文件
apriltag/example/
apriltag/test/
apriltag/src/main/cpp/example/
apriltag/src/main/cpp/test/

# AprilTag Python bindings (not used in Android app)
apriltag/*pywrap*
apriltag/*.docstring

# AprilTag顶层的文件
apriltag/CMake/
apriltag/common/
apriltag/*.c
apriltag/*.h

tagCircle*.c
tagCircle*.h
tagCustom*.c
tagCustom*.h
tagStandard*.c
tagStandard*.h

# AprilTag documentation files (not essential for compilation)
apriltag/README.md
apriltag/LICENSE.md

# AprilTag extra resources
apriltag/tag_size_48h12.png
apriltag/src/main/cpp/tag_size_48h12.png

# AprilTag repository artifacts
apriltag/.github/
apriltag/apriltag-master/