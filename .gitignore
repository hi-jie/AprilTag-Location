# Ignore Gradle build output directory
build

# Ignore VSCode configuration directory
.vscode/

# Built application files
*.apk
*.aar
*.jar
*.so

# Files for the ART/Dalvik VM
*.dex

# Java class files
*.class

# Generated files
bin/
gen/
out/

# Android Studio Navigation editor temp files
.navigation/

# The gradle daemon caches between builds
.gradle
.cxx/
.build/

# Local configuration file (sdk path, etc)
local.properties

# Proguard folder generated by ProGuard
.proguard/

# Log Files
*.log

# Android Studio captures
*.cap

# Firebase Realtime Config Template
google-services.json

# External Native Build outputs
.externalNativeBuild
.cxx/
*.so

# NDK
obj/
.libs/

# AprilTag library specific ignores
# Build directories
apriltag/build/
apriltag/.cxx/
apriltag/obj/
apriltag/.build/

# AprilTag example and test files (not needed for the app)
apriltag/example/
apriltag/test/

# AprilTag Python bindings (not used in Android app)
apriltag/*pywrap*
apriltag/*.docstring

# AprilTag extra tag families not currently used (optional, can be kept if needed)
apriltag/tagCircle*.c
apriltag/tagCircle*.h
apriltag/tagCustom*.c
apriltag/tagCustom*.h
apriltag/tagStandard*.c
apriltag/tagStandard*.h

# AprilTag documentation files (not essential for compilation)
apriltag/README.md
apriltag/LICENSE.md

# AprilTag extra resources
apriltag/tag_size_48h12.png

# AprilTag repository artifacts
apriltag/.github/
apriltag/apriltag-master/